{
  "name": "startup-market",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/migrate.js && next start -p ${PORT:-3000}",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "sync": "tsx cron/run-sync.ts",
    "sync:yc": "tsx cron/run-sync.ts --source yc --full",
    "sync:ph": "tsx cron/run-sync.ts --source producthunt --days 30",
    "sync:cb": "tsx cron/run-sync.ts --source crunchbase",
    "sync:translate": "tsx cron/run-sync.ts --translate-all",
    "sync:telegram": "tsx cron/run-sync.ts --source telegram",
    "sync:rankings": "tsx cron/run-sync.ts --compute-rankings",
    "sync:all": "tsx cron/run-sync.ts --all",
    "sync:xlsx": "tsx cron/import-xlsx.ts",
    "cron": "tsx cron/scheduler.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "graphql-request": "^7.4.0",
    "next": "16.2.2",
    "node-cron": "^4.2.1",
    "node-html-parser": "^7.1.0",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
